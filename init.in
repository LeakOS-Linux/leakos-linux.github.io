#!/bin/sh
# Init script for custom LFS Live ISO - Coreutils version (no BusyBox)

PATH=/usr/bin:/usr/sbin:/bin:/sbin
export PATH

DEBUG=false
rootdelay=

# mnt_tmp sebagai GLOBAL
mnt_tmp="/tmpmnt"

log_msg() {
  local msg="[INIT] $*"
  if ! echo "$msg" > /dev/kmsg 2>/dev/null; then
    echo "$msg"
  fi
}

problem() {
  log_msg "ERROR: Problem detected!"
  printf "\nEncountered a problem!\nDropping to emergency shell...\n\n"
  printf "Useful commands: lsblk, blkid, losetup, ls, mount, dmesg\n\n"
  exec /bin/sh
}

# Cari init di berbagai lokasi umum
find_init() {
  for candidate in \
    /sbin/init \
    /usr/sbin/init \
    /usr/bin/init \
    /usr/local/bin/init \
    /usr/lib/systemd/systemd \
    /lib/systemd/systemd \
    /usr/lib/sysvinit/init \
    /bin/init \
    /bin/sh
  do
    if [ -x "/.root${candidate}" ]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

# =====================================================
# try_mount: GLOBAL (bukan nested) agar kompatibel
# dengan semua sh/dash/ash
# =====================================================
try_mount() {
  local d="$1"
  [ -b "$d" ] || return 1
  # exfat ditambahkan — beberapa USB modern pakai exFAT
  for fstype in iso9660 vfat exfat ext4 ext3 ext2 xfs btrfs auto; do
    if mount -t "$fstype" -o ro "$d" "$mnt_tmp" 2>/dev/null; then
      if [ -f "$mnt_tmp/boot/lfs.squashfs" ]; then
        return 0
      fi
      umount "$mnt_tmp" 2>/dev/null
    fi
  done
  return 1
}

# =====================================================
# find_boot_device: scan semua media secara berurutan
# =====================================================
find_boot_device() {
  local timeout=90
  local count=0

  log_msg "Auto-detecting boot media (timeout: ${timeout}s)..."
  log_msg "Looking for /boot/lfs.squashfs on available devices..."

  mkdir -p "$mnt_tmp" 2>/dev/null

  # Tunggu udev settle — penting agar loop device & USB sudah terdaftar
  # sebelum mulai scan (kritis untuk Ventoy)
  log_msg "Waiting for udev to settle..."
  udevadm settle --timeout=10 2>/dev/null || sleep 3

  while [ $count -lt $timeout ]; do

    # --------------------------------------------------
    # PRIORITAS 1: Loop device aktif (Ventoy)
    # Ventoy mount ISO ke /dev/loop*, probe langsung
    # (jangan pakai `losetup -l` — bisa kosong saat awal)
    # --------------------------------------------------
    for dev in /dev/loop0 /dev/loop1 /dev/loop2 /dev/loop3 \
               /dev/loop4 /dev/loop5 /dev/loop6 /dev/loop7; do
      [ -b "$dev" ] || continue
      # Skip loop device yang tidak punya backing file
      losetup "$dev" 2>/dev/null | grep -q '/' || continue
      log_msg "Probing loop $dev (Ventoy)..."
      if try_mount "$dev"; then
        device="$dev"
        log_msg "Boot media DETECTED on loop $dev (Ventoy)"
        return 0
      fi
    done

    # --------------------------------------------------
    # PRIORITAS 2: USB removable (sdb, sdc, sdd, sde)
    # Coba partisi dulu baru disk penuh
    # --------------------------------------------------
    for dev in \
      /dev/sdb1 /dev/sdb2 /dev/sdb3 /dev/sdb \
      /dev/sdc1 /dev/sdc2 /dev/sdc3 /dev/sdc \
      /dev/sdd1 /dev/sdd2 /dev/sdd3 /dev/sdd \
      /dev/sde1 /dev/sde2 /dev/sde3 /dev/sde; do
      [ -b "$dev" ] || continue
      log_msg "Probing USB $dev..."
      if try_mount "$dev"; then
        device="$dev"
        log_msg "Boot media DETECTED on USB $dev"
        return 0
      fi
    done

    # --------------------------------------------------
    # PRIORITAS 3: Optical (sr*, cdrom, dvd)
    # Rufus ISO mode burn ke CD/DVD, atau boot dari optik
    # --------------------------------------------------
    for dev in /dev/sr0 /dev/sr1 /dev/cdrom /dev/cdrom1 /dev/dvd /dev/dvd1; do
      [ -b "$dev" ] || continue
      log_msg "Probing optical $dev..."
      if try_mount "$dev"; then
        device="$dev"
        log_msg "Boot media DETECTED on optical $dev"
        return 0
      fi
    done

    # --------------------------------------------------
    # PRIORITAS 4: NVMe (partisi dulu, lalu disk penuh)
    # --------------------------------------------------
    for dev in \
      /dev/nvme0n1p1 /dev/nvme0n1p2 /dev/nvme0n1p3 /dev/nvme0n1 \
      /dev/nvme1n1p1 /dev/nvme1n1p2 /dev/nvme1n1p3 /dev/nvme1n1; do
      [ -b "$dev" ] || continue
      log_msg "Probing NVMe $dev..."
      if try_mount "$dev"; then
        device="$dev"
        log_msg "Boot media DETECTED on NVMe $dev"
        return 0
      fi
    done

    # --------------------------------------------------
    # PRIORITAS 5: VirtIO (QEMU/KVM/VirtualBox)
    # --------------------------------------------------
    for dev in \
      /dev/vda1 /dev/vda2 /dev/vda \
      /dev/vdb1 /dev/vdb2 /dev/vdb; do
      [ -b "$dev" ] || continue
      log_msg "Probing VirtIO $dev..."
      if try_mount "$dev"; then
        device="$dev"
        log_msg "Boot media DETECTED on VirtIO $dev"
        return 0
      fi
    done

    # --------------------------------------------------
    # PRIORITAS 6: eMMC / SD card
    # --------------------------------------------------
    for dev in \
      /dev/mmcblk0p1 /dev/mmcblk0p2 /dev/mmcblk0p3 /dev/mmcblk0 \
      /dev/mmcblk1p1 /dev/mmcblk1p2 /dev/mmcblk1p3 /dev/mmcblk1; do
      [ -b "$dev" ] || continue
      log_msg "Probing eMMC $dev..."
      if try_mount "$dev"; then
        device="$dev"
        log_msg "Boot media DETECTED on eMMC $dev"
        return 0
      fi
    done

    # --------------------------------------------------
    # PRIORITAS 7: sda — internal disk / Rufus DD mode
    # Diletakkan terakhir agar tidak salah mount OS utama
    # --------------------------------------------------
    for dev in /dev/sda1 /dev/sda2 /dev/sda3 /dev/sda; do
      [ -b "$dev" ] || continue
      log_msg "Probing $dev..."
      if try_mount "$dev"; then
        device="$dev"
        log_msg "Boot media DETECTED on $dev"
        return 0
      fi
    done

    # --------------------------------------------------
    # PRIORITAS 8: Fallback lsblk — device tidak terduga
    # Pisah setiap pattern ke baris sendiri (fix syntax bug)
    # --------------------------------------------------
    for dev in $(lsblk -pnlo NAME 2>/dev/null); do
      [ -b "$dev" ] || continue
      case "$dev" in
        /dev/loop[0-9]*)  continue ;;
        /dev/sd[a-z]*)    continue ;;
        /dev/nvme*)       continue ;;
        /dev/vd[a-z]*)    continue ;;
        /dev/mmcblk*)     continue ;;
        /dev/sr*)         continue ;;
        /dev/cdrom*)      continue ;;
        /dev/dvd*)        continue ;;
      esac
      log_msg "Probing fallback $dev..."
      if try_mount "$dev"; then
        device="$dev"
        log_msg "Boot media DETECTED on fallback $dev"
        return 0
      fi
    done

    sleep 2
    count=$((count + 2))
    [ $((count % 10)) -eq 0 ] && log_msg "Still scanning... (${count}s elapsed)"
  done

  log_msg "ERROR: No valid boot media found after ${timeout}s"
  log_msg "=== blkid ==="
  blkid 2>/dev/null || true
  log_msg "=== lsblk ==="
  lsblk -f 2>/dev/null || true
  log_msg "=== losetup ==="
  losetup -l 2>/dev/null || true
  problem
  return 1
}

ensure_users() {
  log_msg "Ensuring user database exists in overlay..."

  if [ ! -f /.root/etc/passwd ] || [ ! -s /.root/etc/passwd ]; then
    log_msg "Creating minimal /etc/passwd in overlay..."
    cat > /.root/etc/passwd << 'EOF'
root:x:0:0:root:/root:/bin/bash
live:x:1000:1000:Live User:/home/live:/bin/bash
nobody:x:65534:65534:nobody:/nonexistent:/usr/sbin/nologin
EOF
  fi

  if [ ! -f /.root/etc/group ] || [ ! -s /.root/etc/group ]; then
    log_msg "Creating minimal /etc/group in overlay..."
    cat > /.root/etc/group << 'EOF'
root:x:0:
live:x:1000:
nogroup:x:65534:
EOF
  fi

  if [ ! -f /.root/etc/shadow ] || [ ! -s /.root/etc/shadow ]; then
    log_msg "Creating minimal /etc/shadow in overlay..."
    cat > /.root/etc/shadow << 'EOF'
root:*:19490:0:99999:7:::
live:$6$2AJ3utKN719Q90VR$oTTnjl.5uXDdizR7sBS8kasr6u0kc5CD5XiWLKbv1jA8K6RsM6/362dWveOy7fSZaxpgIPywXx6.k6lHBkkNW1:19490:0:99999:7:::
nobody:*:19490:0:99999:7:::
EOF
    chmod 600 /.root/etc/shadow
  fi

  mkdir -p /.root/etc/pam.d

  cat > /.root/etc/pam.d/common-auth << 'EOF'
auth    sufficient      pam_unix.so nullok
auth    required        pam_deny.so
EOF

  cat > /.root/etc/pam.d/common-account << 'EOF'
account sufficient      pam_unix.so
EOF

  cat > /.root/etc/pam.d/common-session << 'EOF'
session sufficient      pam_unix.so
EOF

  cat > /.root/etc/pam.d/common-password << 'EOF'
password sufficient      pam_unix.so nullok sha512 shadow
EOF

  cat > /.root/etc/pam.d/login << 'EOF'
auth       include      common-auth
account    include      common-account
session    include      common-session
password   include      common-password
EOF

  chmod 600 /.root/etc/shadow 2>/dev/null || true
  chmod 644 /.root/etc/passwd 2>/dev/null || true
  chmod 644 /.root/etc/group  2>/dev/null || true

  mkdir -p /.root/etc/sudoers.d
  cat > /.root/etc/sudoers << 'EOF'
# /etc/sudoers
Defaults env_reset
Defaults mail_badpass
Defaults secure_path="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

root    ALL=(ALL:ALL) ALL
%sudo   ALL=(ALL:ALL) ALL
live    ALL=(ALL:ALL) ALL
EOF
  chmod 440 /.root/etc/sudoers

  if ! grep -q "^sudo:" /.root/etc/group 2>/dev/null; then
    echo "sudo:x:27:live" >> /.root/etc/group
  fi
  if ! grep -q "^wheel:" /.root/etc/group 2>/dev/null; then
    echo "wheel:x:10:live" >> /.root/etc/group
  fi

  cat > /.root/etc/pam.d/sudo << 'EOF'
auth       sufficient   pam_unix.so nullok
account    sufficient   pam_unix.so
session    sufficient   pam_unix.so
EOF

  if [ ! -d /.root/home/live ]; then
    log_msg "Creating home directory for live user with standard folders..."
    mkdir -p /.root/home/live
    mkdir -p /.root/home/live/{Desktop,Documents,Downloads,Music,Pictures,Videos}
    mkdir -p /.root/home/live/{.local/share,.config,.cache,.ssh,.gnupg}
    mkdir -p /.root/home/live/{temp,bin}
    chown -R 1000:1000 /.root/home/live
    chmod 700 /.root/home/live
    chmod 755 /.root/home/live/{Desktop,Documents,Downloads,Music,Pictures,Videos}
    chmod 700 /.root/home/live/{.ssh,.gnupg}
    log_msg "Created standard folders for live user"
  else
    log_msg "Home directory exists, ensuring standard folders..."
    for folder in Desktop Documents Downloads Music Pictures Videos; do
      if [ ! -d "/.root/home/live/$folder" ]; then
        mkdir -p "/.root/home/live/$folder"
        chown 1000:1000 "/.root/home/live/$folder"
        chmod 755 "/.root/home/live/$folder"
      fi
    done
  fi

  if [ ! -d /.root/etc/skel ]; then
    log_msg "Creating /etc/skel with standard folders..."
    mkdir -p /.root/etc/skel
    mkdir -p /.root/etc/skel/{Desktop,Documents,Downloads,Music,Pictures,Videos}
    mkdir -p /.root/etc/skel/{.local/share,.config,.cache}

    cat > /.root/etc/skel/README.txt << 'EOF'
Welcome to your new LFS system!

This is your home directory. Standard folders have been created:
- Desktop    : For desktop files
- Documents  : For documents
- Downloads  : For downloaded files
- Music      : For music files
- Pictures   : For images
- Videos     : For video files
Enjoy your LFS experience!
EOF

    cat > /.root/etc/skel/.bashrc << 'EOF'
case $- in
    *i*) ;;
      *) return;;
esac

HISTCONTROL=ignoreboth
shopt -s histappend
HISTSIZE=1000
HISTFILESIZE=2000
shopt -s checkwinsize

case "$TERM" in
    xterm-color|*-256color) color_prompt=yes;;
esac

if [ "$color_prompt" = yes ]; then
    PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
    PS1='\u@\h:\w\$ '
fi
unset color_prompt force_color_prompt

if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
fi

alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

[ -f ~/.bash_aliases ] && . ~/.bash_aliases
EOF

    cat > /.root/etc/skel/.profile << 'EOF'
[ -n "$BASH_VERSION" ] && [ -f "$HOME/.bashrc" ] && . "$HOME/.bashrc"
[ -d "$HOME/bin" ] && PATH="$HOME/bin:$PATH"
[ -d "$HOME/.local/bin" ] && PATH="$HOME/.local/bin:$PATH"
EOF

    chmod 644 /.root/etc/skel/.bashrc /.root/etc/skel/.profile
    log_msg "/etc/skel created with standard configuration"
  fi

  if [ ! -f /.root/home/live/.config/user-dirs.dirs ]; then
    mkdir -p /.root/home/live/.config
    cat > /.root/home/live/.config/user-dirs.dirs << 'EOF'
XDG_DESKTOP_DIR="$HOME/Desktop"
XDG_DOCUMENTS_DIR="$HOME/Documents"
XDG_DOWNLOAD_DIR="$HOME/Downloads"
XDG_MUSIC_DIR="$HOME/Music"
XDG_PICTURES_DIR="$HOME/Pictures"
XDG_VIDEOS_DIR="$HOME/Videos"

EOF
    chown -R 1000:1000 /.root/home/live/.config
  fi

  if [ ! -f /.root/home/live/.config/user-dirs.locale ]; then
    echo "en_US" > /.root/home/live/.config/user-dirs.locale
    chown 1000:1000 /.root/home/live/.config/user-dirs.locale
  fi

  if [ ! -f /.root/home/live/.bashrc ]; then
    log_msg "Copying skel files to live user home..."
    cp -r /.root/etc/skel/. /.root/home/live/ 2>/dev/null || true
    chown -R 1000:1000 /.root/home/live/
  fi

  if [ ! -f /.root/home/live/.Xresources ]; then
    log_msg "Adding .Xresources for live user..."
    cat > /.root/home/live/.Xresources << 'EOF'
! ~/.Xresources
*foreground:                  #00FF00
*background:                  #000000

urxvt.font:                   xft:xos4 Terminus:size=10:style=bold:antialias=true:hinting=true
urxvt.url-launcher:           /usr/bin/xdg-open
urxvt.matcher.button:         1
urxvt.scrollBar:              false
urxvt.termName:               xterm-256color
urxvt.saveLines:              10000
urxvt.inheritPixmap:          true
urxvt.shading:                20
urxvt.clipboard.autocopy:     true
urxvt.perl-ext-common:        default,selection-to-clipboard,pasta,matcher,keyboard-select,resize-font,font
urxvt.keysym.M-u:             perl:url-select:select_next
urxvt.transparent:            true
urxvt.buffered:               true
urxvt.jumpScroll:             false
urxvt.scrollTtyKeypress:      true
urxvt.scrollTtyOutput:        false
urxvt.scrollWithBuffer:       false
urxvt.scrollstyle:            plain
urxvt.secondaryScroll:        false
urxvt.xftAntialias:           true
urxvt.color12:                RoyalBlue
urxvt.matcher.rend.0:         Bold fg6
urxvt.cursorBlink:            false
urxvt.cursorColor:            RoyalBlue
urxvt.mapAlert:               true
urxvt.pointerBlank:           true
urxvt.iso14755:               false
urxvt.iso14755_52:            false
URxvt.geometry:               55x24

xterm*VT100*geometry:         80x30
xterm*faceName:               xft:Terminus:size=13:style=Bold
xterm*faceSize:               13
xterm*renderFont:             true
XTerm*utf8:                   always
xterm*utf8Title:              true
xterm*locale:                 true
xterm*cursorColor:            #fff
xterm*cursorBlink:            false
xterm*selectToClipboard:      true
xterm*SaveLines:              10000
xterm*transparent:            true
XTerm*trimSelection:          true
XTerm*cutNewline:             false
XTerm*highlightSelection:     true
xterm*foreground:             #ffffff

Xcursor.theme:                Adwaita
Xcursor.size:                 12
xft.antialias:                true
EOF
    chown 1000:1000 /.root/home/live/.Xresources
    chmod 644 /.root/home/live/.Xresources
    log_msg ".Xresources added"
  fi

  log_msg "User setup complete with all standard folders"
}


do_mount_root() {
  log_msg "Mounting root filesystem (squashfs + overlay)"

  modprobe -q squashfs   || true
  modprobe -q overlay    || true
  modprobe -q loop       || true
  modprobe -q vfat       || true
  modprobe -q exfat      || true
  modprobe -q iso9660    || true
  modprobe -q usb-storage || true
  modprobe -q r8188eu || true
  modprobe -q e1000 || true
  modprobe -q e1000e || true
  modprobe -q pcnet32 || true
  modprobe -q sr_mod     || true
  modprobe -q xhci_hcd   || true
  modprobe -q ehci_hcd   || true
  modprobe -q uhci_hcd   || true
  modprobe -q vboxvideo  || true
  modprobe -q virtio_gpu || true
  modprobe -q vmwgfx     || true
  modprobe -q drm        || true
  modprobe -q virtio_net || true
  modprobe -q loop max_loop=64 || true
  modprobe -q dm_mod     || true

  mkdir -p /.root /mnt /squash /cow/mod /cow/buffer

  [ -b /dev/loop0 ] || mknod /dev/loop0 b 7 0

  if ! find_boot_device; then
    return 1
  fi

  # Move atau remount ke /mnt
  if mountpoint -q "$mnt_tmp" 2>/dev/null; then
    mount --move "$mnt_tmp" /mnt || problem
  else
    mount -t auto "$device" /mnt || { log_msg "Mount $device failed"; problem; }
  fi
  log_msg "Boot media mounted at /mnt"

  [ -f /mnt/boot/lfs.squashfs ] || { log_msg "lfs.squashfs missing!"; ls -la /mnt/boot/; problem; }

  mount -t squashfs -o loop /mnt/boot/lfs.squashfs /squash || problem
  log_msg "squashfs mounted at /squash"

  mount -t tmpfs tmpfs /cow || problem
  mkdir -p /cow/mod /cow/buffer

  # Buat direktori di upperdir SEBELUM overlay di-mount
  mkdir -p /cow/mod/dev /cow/mod/proc /cow/mod/sys /cow/mod/run
  mkdir -p /cow/mod/mnt/changes /cow/mod/mnt/container
  mkdir -p /cow/mod/dev/pts

  mount -t overlay -o lowerdir=/squash,upperdir=/cow/mod,workdir=/cow/buffer overlay /.root || problem
  log_msg "Overlay mounted at /.root"

  ensure_users

  mount --bind /cow/mod /.root/mnt/changes || true
  mount --bind /mnt /.root/mnt/container   || true

  log_msg "Binding pseudo-filesystems to new root..."
  mount --bind /dev  /.root/dev  || log_msg "WARNING: bind /dev failed"
  mount --bind /proc /.root/proc || log_msg "WARNING: bind /proc failed"
  mount --bind /sys  /.root/sys  || log_msg "WARNING: bind /sys failed"
  mount --bind /run  /.root/run  || log_msg "WARNING: bind /run failed"
  mount -t devpts devpts /.root/dev/pts -o gid=5,mode=620 2>/dev/null || true

  log_msg "Root filesystem prepared!"
}


# ===================== MAIN =====================

log_msg "=== LeakOS Live ISO Init Starting ==="

mkdir -p /proc /sys /dev /run /tmp 2>/dev/null

log_msg "Mounting pseudo-filesystems..."
mount -t devtmpfs devtmpfs /dev 2>/dev/null || { log_msg "devtmpfs failed"; /bin/sh; }
mount -t proc proc /proc || { log_msg "CRITICAL: proc mount failed!"; /bin/sh; }
mount -t sysfs sysfs /sys 2>/dev/null || log_msg "sysfs mount failed (non-fatal)"
mount -t tmpfs tmpfs /run 2>/dev/null || log_msg "tmpfs /run failed (non-fatal)"
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts -o gid=5,mode=620 2>/dev/null || log_msg "devpts mount failed"

if [ ! -r /proc/cmdline ]; then
  log_msg "WARNING: /proc/cmdline missing - remounting /proc"
  umount /proc 2>/dev/null
  mount -t proc proc /proc || { log_msg "Cannot remount /proc!"; /bin/sh; }
fi

cmdline=$(cat /proc/cmdline 2>/dev/null || echo "")
log_msg "Kernel cmdline: $cmdline"

for param in $cmdline; do
  case $param in
    debug)        DEBUG=true ;;
    rootdelay=*)  rootdelay=${param#rootdelay=} ;;
  esac
done

# Start udev — daemon DULU, baru trigger
log_msg "Starting udev..."
UDEVD=""
for p in /usr/bin/udevd /usr/sbin/udevd /sbin/udevd /lib/udev/udevd /usr/lib/udev/udevd /usr/lib/systemd/systemd-udevd; do
  [ -x "$p" ] && UDEVD="$p" && break
done

if [ -z "$UDEVD" ]; then
  log_msg "WARNING: udevd not found, using mdev fallback"
  mdev -s 2>/dev/null || true
else
  $UDEVD --daemon --resolve-names=never 2>/dev/null
  sleep 1
  udevadm trigger --action=add 2>/dev/null || true
  udevadm settle --timeout=10 2>/dev/null || true
  log_msg "udev ready"
fi

[ -n "$rootdelay" ] && { log_msg "rootdelay ${rootdelay}s"; sleep "$rootdelay"; }

do_mount_root || problem

log_msg "Stopping udev..."
killall -q udevd 2>/dev/null || killall -q systemd-udevd 2>/dev/null || true

# Cari init yang valid di new root
INIT_PATH=$(find_init)
if [ -z "$INIT_PATH" ]; then
  log_msg "FATAL: No valid init found in /.root!"
  log_msg "Contents of /.root/sbin:"
  ls -la /.root/sbin/ 2>/dev/null || true
  log_msg "Contents of /.root/usr/sbin:"
  ls -la /.root/usr/sbin/ 2>/dev/null || true
  log_msg "Contents of /.root/usr/lib/systemd:"
  ls -la /.root/usr/lib/systemd/ 2>/dev/null || true
  problem
fi

log_msg "Switching to new root with init: $INIT_PATH"
exec switch_root /.root "$INIT_PATH" "$@"

log_msg "FATAL: switch_root failed! INIT_PATH=$INIT_PATH"
ls -la /.root/sbin /.root/usr/sbin 2>/dev/null || true
problem